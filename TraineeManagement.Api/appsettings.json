{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System": "Error"
    }
  },
  "Debug": {
    "LogLevel": {
      "Default": "Debug"
    }
  },
  "Console": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "SET_IN_ENV",
    "Issuer": "SET_IN_ENV",
    "Audience": "SET_IN_ENV",
    "ExpiryMinutes": 60
  },
  "AdminUser": {
    "Username": "SET_IN_ENV",
    "Password": "SET_IN_ENV",
    "Email": "SET_IN_ENV"
  },
  "FileStorage": {
    "RootPath": "Uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [
      ".pdf",
      ".docx",
      ".txt",
      ".zip",
      ".jpeg",
      ".png",
      ".jpg",
      ".svg"
    ],
    "AllowedContentTypes": [
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "text/plain",
      "application/zip",
      "image/jpeg",
      "image/png",
      "image/svg+xml"
    ]
  },
  "Redis": {
    "ConnectionString": "SET_IN_ENV",
    "InstanceName": "SET_IN_ENV",
    "DefaultItlSeconds": 600
  },
  "RabbitMq": {
    "HostName": "SET_IN_ENV",
    "Port": 5672,
    "VirtualHost": "SET_IN_ENV",
    "UserName": "SET_IN_ENV",
    "Password": "SET_IN_ENV",
    "SubmissionQueue": "submission-processing",
    "SubmissionQueueExchange": "submission-exchange",
    "SubmissionRoutingKey": "requested",
    "DlxName" : "submission-dlx",
    "DlqName" : "submission-processing-dlq",
    "RoutingKey" : "failed",
    "MaxRetryAttempts" : 3
  },
  "HealthChecks" : {
    "TrainingDirectoryHealthUrl" : "SET_IN_ENV"
  }
}
